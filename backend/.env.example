# ClipForge backend configuration. Copy to .env and fill in.
# Field names map to settings in app/core/config.py (env var = UPPERCASE name).

# --- Core ---
ENVIRONMENT=development
# JSON list of allowed browser origins for the frontend (CORS).
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
# Max seconds a queued job may run. CPU Whisper + FFMPEG can be slow; keep generous.
JOB_TIMEOUT_SEC=7200

# --- Data layer (point at managed Postgres/Redis/S3 in production) ---
DATABASE_URL=postgresql+psycopg://clipforge:clipforge@localhost:5432/clipforge
REDIS_URL=redis://localhost:6379/0
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=clipforge-media
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# --- AI / ML ---
ANTHROPIC_API_KEY=sk-ant-...
SEGMENT_SELECTION_MODEL=claude-sonnet-4-6
# Transcription provider: whisper_local (default). Deepgram/AssemblyAI = future (OQ-02).
TRANSCRIPTION_PROVIDER=whisper_local
# faster-whisper model: tiny|base|small|medium|large-v3. tiny=fast, base=balanced.
WHISPER_MODEL=base
WHISPER_COMPUTE_TYPE=int8
# Min inter-word gap (sec) treated as a silence/cut boundary (FR-09/FR-15).
SILENCE_GAP_SEC=0.4

# --- Pipeline / render ---
DEFAULT_TARGET_MIN_SEC=180
DEFAULT_TARGET_MAX_SEC=240
NUDGE_STEP_SEC=0.5
# FFmpeg binary. "ffmpeg" if on PATH; else an absolute path (needed for render, B7).
FFMPEG_BIN=ffmpeg
OUTPUT_RESOLUTION=1080p
